{
  "project": "finanzas-cmf",
  "description": "Cumplimiento financiero — CMF · AML/KYC · Ley 19.913 (Chile)",
  "repo": ".",
  "lang": "es",
  "adapter": "file",
  "default_task": "evaluar-politica-aml",

  "agents": {
    "domain": "base",
    "use": ["compliance-officer"],
    "custom": []
  },
  "skills": {
    "domain": "finanzas",
    "use": ["cmf-compliance", "aml-kyc"],
    "custom": []
  },

  "variables": {
    "empresa":           "Mi Institución Financiera",
    "tipo_entidad":      "corredora de bolsa",
    "regulador":         "CMF — Comisión para el Mercado Financiero",
    "oficial_cumplimiento": "Nombre del Oficial de Cumplimiento",
    "email_compliance":  "compliance@empresa.cl"
  },

  "tasks": {
    "evaluar-politica-aml": {
      "prompt": "evaluar-cumplimiento-financiero",
      "variables": { "tipo_documento": "política AML/KYC", "norma_principal": "Ley 19.913" }
    },
    "evaluar-contrato-cliente": {
      "prompt": "evaluar-cumplimiento-financiero",
      "variables": { "tipo_documento": "contrato con cliente", "norma_principal": "Ley 18.045 + Ley 20.555" }
    },
    "evaluar-manual-compliance": {
      "prompt": "evaluar-cumplimiento-financiero",
      "variables": { "tipo_documento": "manual de compliance", "norma_principal": "NCG 461 CMF" }
    },
    "evaluar-politica-ciberseguridad": {
      "prompt": "evaluar-cumplimiento-financiero",
      "skills": ["cmf-compliance"],
      "variables": { "tipo_documento": "política de ciberseguridad", "norma_principal": "NCG 380 CMF" }
    }
  },

  "llm_profile": {
    "type":     "powerful",
    "provider": "claude",
    "model":    "claude-sonnet-4-6"
  },
  "embedding": {
    "provider": "ollama",
    "model":    "bge-m3",
    "base_url": "http://localhost:11434"
  },
  "reranker": {
    "provider":  "ollama",
    "model":     "bge-reranker-v2-m3",
    "base_url":  "http://localhost:11434",
    "min_score": 0.7
  }
}
