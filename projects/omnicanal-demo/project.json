{
  "project": "omnicanal-demo",
  "description": "Acme Services — Omnicanal Empresarial",
  "repo": ".",
  "lang": "es",
  "adapter": "file",
  "default_task": "ventas-whatsapp",

  "agents": { "domain": "callcenter", "use": [] },
  "skills": { "domain": "callcenter", "use": [] },

  "variables": {
    "empresa": "Acme Services",
    "producto": "Plan Enterprise",
    "precio_base": "USD 299/mes",
    "descuento_maximo": "25%",
    "periodo_prueba": "30 días"
  },

  "tasks": {
    "ventas-whatsapp": {
      "agents": ["ejecutivo-ventas"],
      "skills": ["politica-ventas", "objeciones"],
      "prompt": "respuesta-ventas",
      "variables": { "canal": "whatsapp", "etapa": "primer-contacto" }
    },
    "ventas-webchat": {
      "agents": ["ejecutivo-ventas"],
      "skills": ["politica-ventas", "objeciones"],
      "prompt": "respuesta-ventas",
      "variables": { "canal": "webchat", "etapa": "primer-contacto" }
    },
    "ivr-menu": {
      "agents": ["asistente-ivr"],
      "skills": ["rutas-ivr"],
      "prompt": "respuesta-ivr"
    },
    "cobranza-temprana": {
      "agents": ["ejecutivo-ventas"],
      "skills": ["politica-cobranza"],
      "prompt": "respuesta-cobranza",
      "variables": { "etapa_deuda": "temprana", "dias_mora": "20", "monto_pendiente": "USD 598" }
    },
    "cobranza-tardia": {
      "agents": ["ejecutivo-ventas"],
      "skills": ["politica-cobranza"],
      "prompt": "respuesta-cobranza",
      "variables": { "etapa_deuda": "tardía", "dias_mora": "75", "monto_pendiente": "USD 1495" }
    }
  },

  "llm_profile": {
    "type": "powerful",
    "provider": "claude",
    "model": "claude-sonnet-4-6"
  }
}
