{
  "project": "pruebas-locales",
  "description": "Ejemplo mínimo oficial — API de tareas para validar Mova Context de punta a punta",
  "repo": "examples/pruebas-locales-repo",
  "lang": "es",
  "adapter": "file",
  "default_task": "crear-proyecto",

  "agents": { "domain": "base", "use": ["backend-dev"], "custom": [] },
  "skills": { "domain": "base", "use": ["lazy-minimalism"], "custom": [] },

  "variables": {
    "stack": "Node.js + Express + SQLite",
    "database": "SQLite",
    "auth_method": "API key simple (header X-API-Key)",
    "test_framework": "node:test",
    "ci_provider": "GitHub Actions",
    "forbidden": "Docker · dependencias no declaradas · .env · CI/CD · logging avanzado"
  },

  "tasks": {
    "crear-proyecto": {
      "prompt": "create-project",
      "variables": {
        "project_name": "tareas-api",
        "description": "API mínima de tareas con 3 endpoints: crear, listar, marcar completada"
      }
    },
    "agregar-modulo": {
      "prompt": "create-module",
      "variables": { "module": "categorias", "api_prefix": "/api/v1" }
    },
    "auditar-modulo": {
      "prompt": "audit-module",
      "agents": ["security-architect"],
      "variables": { "module": "tareas" }
    },
    "configurar-cicd": {
      "prompt": "cicd-setup",
      "agents": ["devops-engineer"]
    },
    "generar-tests": {
      "prompt": "create-module",
      "agents": ["qa-engineer"],
      "skills": ["generate-tests"],
      "variables": { "module": "tareas" }
    },
    "revisar-demo-local": {
      "prompt": "review-project",
      "focus": [
        "CreateOrder()",
        "ordenes"
      ]
    }
  },

 "llm_profile": {
    "type": "local",
    "provider": "ollama",
    "model": "llama3.2:3b",
    "base_url": "http://localhost:11434"
  }
}
